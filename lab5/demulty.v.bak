`timescale 1ns / 1ps

module demulty (
    input [3:0] data_in,    // 4-???????? ????
    input [2:0] sel,        // 3-??????? ????????
    // ??????? ??????? ????? "reg" ????? ?????? ???????
    output reg [3:0] out0,  
    output reg [3:0] out1,
    output reg [3:0] out2,
    output reg [3:0] out3,
    output reg [3:0] out4,
    output reg [3:0] out5,
    output reg [3:0] out6,
    output reg [3:0] out7
);

    // ???? always ??? ????????????? ??????
    always @(*) begin
        // ???????? "?????????" ??? ??????
        out0 = 4'b0000;
        out1 = 4'b0000;
        out2 = 4'b0000;
        out3 = 4'b0000;
        out4 = 4'b0000;
        out5 = 4'b0000;
        out6 = 4'b0000;
        out7 = 4'b0000;

        // ?????????? ???????? ???????? ??????
        case (sel)
            3'b000: out0 = data_in;
            3'b001: out1 = data_in;
            3'b010: out2 = data_in;
            3'b011: out3 = data_in;
            3'b100: out4 = data_in;
            3'b101: out5 = data_in;
            3'b110: out6 = data_in;
            3'b111: out7 = data_in;
            default: ; 
        endcase
    end

endmodule
